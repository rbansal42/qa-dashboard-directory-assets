{
  "name": "Qatar Airways — Dashboard Directory (v2)",
  "dataColors": [
    "#43061F",
    "#B8893A",
    "#591029",
    "#D9B268",
    "#2A0311",
    "#8E7355",
    "#7A4E1A",
    "#4E1E3A"
  ],
  "background": "#FBF6EC",
  "foreground": "#1A0D12",
  "tableAccent": "#43061F",
  "good": "#2E7D4F",
  "neutral": "#B8893A",
  "bad": "#8C1E2A",
  "maximum": "#2A0311",
  "center": "#B8893A",
  "minimum": "#FBF6EC",
  "null": "#E8DFD0",
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 22,
      "color": "#43061F"
    },
    "header": {
      "fontFace": "Segoe UI",
      "fontSize": 11,
      "color": "#524148"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 12,
      "color": "#1A0D12"
    },
    "callout": {
      "fontFace": "Georgia",
      "fontSize": 36,
      "color": "#2A0311"
    },
    "largeTitle": {
      "fontFace": "Georgia",
      "fontSize": 28,
      "color": "#2A0311"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 0 }],
        "border": [{ "color": { "solid": { "color": "#E8DFD0" } }, "radius": 6, "show": true }],
        "visualHeader": [{ "show": false }]
      }
    },
    "card": {
      "*": {
        "background": [{ "show": false }],
        "border": [{ "show": false }]
      }
    },
    "button": {
      "*": {
        "fill": [{ "show": true, "fillColor": { "solid": { "color": "#43061F" } }, "transparency": 0 }],
        "text": [{ "show": true, "fontColor": { "solid": { "color": "#F7EBD4" } }, "fontFamily": "Segoe UI Semibold", "fontSize": 10, "horizontalAlignment": "center" }],
        "outline": [{ "show": false }]
      }
    },
    "slicer": {
      "*": {
        "background": [{ "show": true, "color": { "solid": { "color": "#FBF6EC" } } }],
        "border": [{ "color": { "solid": { "color": "#D6C9B6" } }, "show": true, "radius": 4 }]
      }
    },
    "pivotTable": {
      "*": {
        "columnHeaders": [{ "fontColor": { "solid": { "color": "#524148" } }, "backColor": { "solid": { "color": "#F3EADA" } }, "fontFamily": "Segoe UI", "fontSize": 9, "bold": true }],
        "values":       [{ "fontColor": { "solid": { "color": "#1A0D12" } }, "backColor": { "solid": { "color": "#FFFFFF" } }, "fontFamily": "Segoe UI", "fontSize": 12 }],
        "grid":         [{ "gridHorizontal": true, "gridVertical": false, "gridHorizontalColor": { "solid": { "color": "#E8DFD0" } }, "gridHorizontalWeight": 1 }],
        "total":        [{ "show": false }]
      }
    }
  }
}
