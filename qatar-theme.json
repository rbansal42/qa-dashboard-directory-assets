{
  "name": "Qatar Airways — Dashboard Directory (v3, brand-strict)",
  "dataColors": [
    "#64003A",
    "#5E6A71",
    "#3C0026",
    "#818A8F",
    "#780044",
    "#6B6C6E",
    "#003F87",
    "#E1E1E2"
  ],
  "background": "#FFFFFF",
  "foreground": "#1A1A1A",
  "tableAccent": "#64003A",
  "good": "#2E7D4F",
  "neutral": "#5E6A71",
  "bad": "#780044",
  "maximum": "#3C0026",
  "center": "#5E6A71",
  "minimum": "#FFFFFF",
  "null": "#E1E1E2",
  "textClasses": {
    "title": {
      "fontFace": "Jotia Light, Noto Sans, Segoe UI Semibold",
      "fontSize": 22,
      "color": "#64003A"
    },
    "header": {
      "fontFace": "Noto Sans, Segoe UI",
      "fontSize": 11,
      "color": "#5E6A71"
    },
    "label": {
      "fontFace": "Noto Sans, Segoe UI",
      "fontSize": 12,
      "color": "#1A1A1A"
    },
    "callout": {
      "fontFace": "Jotia Light, Noto Sans, Georgia",
      "fontSize": 36,
      "color": "#3C0026"
    },
    "largeTitle": {
      "fontFace": "Jotia Light, Noto Sans, Georgia",
      "fontSize": 28,
      "color": "#3C0026"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 0 }],
        "border": [{ "color": { "solid": { "color": "#E1E1E2" } }, "radius": 6, "show": true }],
        "visualHeader": [{ "show": false }]
      }
    },
    "card": {
      "*": {
        "background": [{ "show": false }],
        "border": [{ "show": false }]
      }
    },
    "button": {
      "*": {
        "fill": [{ "show": true, "fillColor": { "solid": { "color": "#64003A" } }, "transparency": 0 }],
        "text": [{ "show": true, "fontColor": { "solid": { "color": "#FFFFFF" } }, "fontFamily": "Noto Sans Medium", "fontSize": 10, "horizontalAlignment": "center" }],
        "outline": [{ "show": false }]
      }
    },
    "slicer": {
      "*": {
        "background": [{ "show": true, "color": { "solid": { "color": "#F0F0F0" } } }],
        "border": [{ "color": { "solid": { "color": "#E1E1E2" } }, "show": true, "radius": 4 }]
      }
    },
    "pivotTable": {
      "*": {
        "columnHeaders": [{ "fontColor": { "solid": { "color": "#5E6A71" } }, "backColor": { "solid": { "color": "#F0F0F0" } }, "fontFamily": "Noto Sans", "fontSize": 9, "bold": true }],
        "values":       [{ "fontColor": { "solid": { "color": "#1A1A1A" } }, "backColor": { "solid": { "color": "#FFFFFF" } }, "fontFamily": "Noto Sans", "fontSize": 12 }],
        "grid":         [{ "gridHorizontal": true, "gridVertical": false, "gridHorizontalColor": { "solid": { "color": "#E1E1E2" } }, "gridHorizontalWeight": 1 }],
        "total":        [{ "show": false }]
      }
    }
  }
}
